# Budgeting (Plaid) — https://dashboard.plaid.com
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=production
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
DATABASE_URL=sqlite:///./money.db

# Investing (tastytrade OAuth) — create an app + personal grant at developer.tastytrade.com.
# prod = real account, READ-ONLY: create the grant with ONLY the read/openid scopes
# (no trade scope). Both values must come from the same OAuth app.
TASTYTRADE_ENV=prod
TASTYTRADE_PROVIDER_SECRET=your_provider_secret
TASTYTRADE_REFRESH_TOKEN=your_refresh_token

# AI copilot (CLAUDE_API_KEY also accepted)
ANTHROPIC_API_KEY=your_anthropic_key
ASSISTANT_MODEL=claude-sonnet-5
